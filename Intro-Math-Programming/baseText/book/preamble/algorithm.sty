%% algorithm.sty - Algorithm environment
%% Minimal implementation for floating algorithm environment
%% Based on the algorithms bundle by Rogério Brito

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{algorithm}[2009/08/24 v0.1 Algorithm environment]

\RequirePackage{float}
\RequirePackage{ifthen}

% Define the algorithm float
\newfloat{algorithm}{htbp}{loa}[chapter]
\floatname{algorithm}{Algorithm}

% List of algorithms
\newcommand{\listofalgorithms}{\listof{algorithm}{List of Algorithms}}

% Options
\DeclareOption{plain}{\floatstyle{plain}\restylefloat{algorithm}}
\DeclareOption{ruled}{\floatstyle{ruled}\restylefloat{algorithm}}
\DeclareOption{boxed}{\floatstyle{boxed}\restylefloat{algorithm}}

\ProcessOptions\relax

\endinput
