\doTocEntry\toclof{}{\csname a:TocLink\endcsname{13}{x13-152002}{}{\numberline {5.1}{\ignorespaces \href {https://www.desmos.com/calculator/j1li4l7lcv}{Desmos: Interactive plot!} (\href {https://open-optimization.github.io/open-optimization-or-book/interactive-figures/lp-graphical-method.html}{backup interactive plot})\relax }}}{235}\relax 
\doTocEntry\tocsection{5.2}{\csname a:TocLink\endcsname{13}{x13-1530005.2}{QQ2-13-169}{Graphical Approach}}{237}\relax 
\doTocEntry\toclof{}{\csname a:TocLink\endcsname{13}{x13-153004}{}{\numberline {5.2}{\ignorespaces Feasible region and level curves for the Furniture Workshop problem. The shaded polygon represents the set of all $(x_1,x_2)$ satisfying every constraint. Dashed lines show the objective function at several values of $z$. As $z$ increases, the level curves sweep upward and to the right.\relax }}}{239}\relax 
\doTocEntry\toclof{}{\csname a:TocLink\endcsname{13}{x13-153011}{}{\numberline {5.3}{\ignorespaces Feasible region and objective level curves for the Lemonade Vendor problem. The shaded polygon is the set of $(x,y)$ satisfying all constraints; dashed lines are level curves $3x+2y = z$ for $z = 0,2,4,6,8$. Sweeping the level curves in the direction of $\nabla z = (3,2)$ shows the optimum is at the vertex $(1.2,1.6)$.\relax }}}{245}\relax 
\doTocEntry\toclof{}{\csname a:TocLink\endcsname{13}{x13-153015}{}{\numberline {5.4}{\ignorespaces Feasible region of a generic linear program with constraints $x_1+x_2\geq 3$, $2x_1-x_2\leq 5$, and $-x_1+2x_2\leq 3$. The shaded triangle illustrates how three linear inequalities can carve out a bounded polygonal region.\relax }}}{248}\relax 
\doTocEntry\tocsection{5.3}{\csname a:TocLink\endcsname{13}{x13-1540005.3}{QQ2-13-173}{Infinitely Many Optimal Solutions}}{249}\relax 
\doTocEntry\toclof{}{\csname a:TocLink\endcsname{13}{x13-154004}{}{\numberline {5.5}{\ignorespaces Alternative optimal solutions: the level curve $z = 80$ (bold blue segment) lies along an entire edge of the feasible region. Every point on this edge is an optimal solution.\relax }}}{252}\relax 
\doTocEntry\tocsection{5.4}{\csname a:TocLink\endcsname{13}{x13-1550005.4}{QQ2-13-175}{Problems with No Solution}}{253}\relax 
\doTocEntry\toclof{}{\csname a:TocLink\endcsname{13}{x13-155004}{}{\numberline {5.6}{\ignorespaces An infeasible linear program. The upper-bound constraints force $x_1+x_2\leq 8$, but the lower bounds require $x_1\geq 7$ and $x_2\geq 5$, so $x_1+x_2\geq 12$. No point can satisfy both conditions, and the feasible region is empty.\relax }}}{256}\relax 
\doTocEntry\tocsection{5.5}{\csname a:TocLink\endcsname{13}{x13-1560005.5}{QQ2-13-177}{Problems with Unbounded Feasible Regions}}{257}\relax 
\doTocEntry\toclof{}{\csname a:TocLink\endcsname{13}{x13-156004}{}{\numberline {5.7}{\ignorespaces An unbounded linear program. The feasible region extends infinitely upward and to the right. Level curves of $z = x_1 + 3x_2$ continue to intersect the feasible region for arbitrarily large $z$, so the problem is unbounded.\relax }}}{261}\relax 
\doTocEntry\toclof{}{\csname a:TocLink\endcsname{13}{x13-156008}{}{\numberline {5.8}{\ignorespaces A linear program with an unbounded feasible region but a finite optimal solution. The minimum of $z = 3x_1+x_2$ occurs at the vertex $(0,2)$ with $z^* = 2$, because the gradient points away from the bounded end of the feasible region.\relax }}}{264}\relax 
